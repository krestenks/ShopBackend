# Environment variables required by ShopBackend (DO NOT put real values in git)
#
# For Upsun/Platform.sh: configure these as environment variables in the project.
# For local development: copy this file to `.env` and fill values, but keep `.env` uncommitted.

# CallApp RapidAPI — set to enable background phone-name screening of customers
# Get your key at https://rapidapi.com/callapp/api/callapp
CALLAPP_RAPIDAPI_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public base URL used to build webhook URLs (e.g. https://<project>.<region>.upsunapp.com)
PUBLIC_BASE_URL=

# JWT signing secret (must be set in production)
JWT_SECRET=

# Web admin login credentials (optional override).
# If set, ADMIN_PASSWORD is compared directly (plain text env var).
# If not set, the hardcoded fallback is: admin / 1234
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
